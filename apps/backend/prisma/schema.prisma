generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================
enum OrderStatus {
  pending
  approved
  delivered
  cancelled
}

enum PaymentMethod {
  card
  cash
}

// ============================================
// CATEGORIAS
// ============================================
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  deletedAt   DateTime?
  
  products    Product[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("categories")
}

// ============================================
// PRODUTOS
// ============================================
model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       Float    @default(0)
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  variations  Json?    @default("[]")
  imageUrl    String?
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  stock       Int      @default(0)
  deletedAt   DateTime?
  views       Int      @default(0)
  
  orderItems  OrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([categoryId])
  @@index([slug])
  @@index([active])
  @@index([deletedAt])
  @@map("products")
}

// ============================================
// STORE (CONFIGURAÇÕES DA LOJA)
// ============================================
model Store {
  id           String   @id @default(uuid())
  name         String   @default("Biolo")
  whatsapp     String   @default("244935751955")
  email        String?
  address      String?
  logo         String?
  primaryColor String   @default("#E05A2A")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("stores")
}

// ============================================
// PEDIDOS
// ============================================
model Order {
  id            String        @id @default(uuid())
  clientName    String
  clientAddress String
  clientPhone   String?
  paymentMethod PaymentMethod
  status        OrderStatus   @default(pending)
  total         Float         @default(0)
  
  items         OrderItem[]
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@map("orders")
}

// ============================================
// ITENS DO PEDIDO
// ============================================
model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  price       Float
  variation   String?
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}