generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/generated/prisma"
  moduleFormat = "cjs"
}
datasource db {
  provider = "postgresql"
}


// ============================================
// CATEGORIAS
// ============================================
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  deletedAt   DateTime?  // ← ADICIONA ISSO
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("categories")
}