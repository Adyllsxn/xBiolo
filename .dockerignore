# Dependências (evita copiar node_modules gigantes)
**/node_modules/
**/npm-debug.log

# Builds
**/dist/
**/build/
**/.next/
**/out/

# Arquivos de ambiente
**/.env
**/.env.local
**/.env.production

# Git e IDE
.git/
.gitignore
.vscode/
.idea/
*.swp

# Logs
**/logs/
**/*.log

# Banco de dados local
**/*.sqlite
**/*.db

# Testes
**/coverage/
**/.nyc_output/
**/test/

